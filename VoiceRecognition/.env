# ============================================================
# Voice Biometric Microservice -- Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.

# --- Database (required) ------------------------------------
# SQLAlchemy connection string.  Examples:
#   MySQL/MariaDB : mysql+pymysql://user:pass@host:3306/dbname
#   PostgreSQL    : postgresql+psycopg2://user:pass@host:5432/dbname
#   SQLite (dev)  : sqlite:///./voice.db
#DATABASE_URL=mysql+pymysql://usuariop:Usuariop!@localhost:3307/pstreaming

DATABASE_URL: mysql+pymysql://usuariop:Usuariop!@host.docker.internal:3307/pstreaming


# --- Security -----------------------------------------------
# API key required in the X-API-Key header. Leave empty to
# disable key checks (development only!).
API_KEY=

# Comma-separated list of allowed CORS origins.
# Use "*" only during development.
ALLOWED_ORIGINS=*

# --- Runtime ------------------------------------------------
# "development" or "production".
# In production, /docs and /redoc are disabled.
ENVIRONMENT=development

# --- FFmpeg paths -------------------------------------------
# Directory containing ffmpeg/ffprobe binaries (added to PATH).
FFMPEG_DIR=ffmpeg

# Full path or name of the ffmpeg binary.
FFMPEG_BIN=ffmpeg

# Full path or name of the ffprobe binary.
FFPROBE_BIN=ffprobe
